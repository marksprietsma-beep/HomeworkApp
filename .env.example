# Local PostgreSQL connection used by Prisma.
# Copy this file to .env before running Prisma commands locally.
DATABASE_URL="postgresql://homework:homework@localhost:5432/homework_app?schema=public"

# Optional: override where locally uploaded assignment question images are stored.
# Defaults to ./data/uploads when unset. Use an absolute mounted data path on a server.
# LOCAL_MEDIA_ROOT=/absolute/path/to/homework-app/uploads
