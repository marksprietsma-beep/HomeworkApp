generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  TEACHER
  STUDENT
}

enum AccountStatus {
  ACTIVE
  DISABLED
}

enum ClassStatus {
  ACTIVE
  INACTIVE
}

enum HomeworkAssignmentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum SubmissionStatus {
  DRAFT
  SUBMITTED
}

enum HomeworkQuestionType {
  OPEN_TEXT
  LONG_TEXT
  MULTIPLE_CHOICE
}

enum HomeworkQuestionResponseMode {
  TEXT
  PSEUDOCODE
}

enum FeedbackFollowUpActionType {
  ACKNOWLEDGEMENT
  SHORT_REFLECTION
  ANSWER_FOLLOW_UP_QUESTION
}

enum FeedbackFollowUpActionStatus {
  PENDING
  COMPLETED
}

enum FeedbackReleaseState {
  DRAFT
  RELEASED
}

enum DepartmentTeamRole {
  MEMBER
  ADMIN
}

enum CurriculumLibraryVisibility {
  PRIVATE
  TEAM
}

model LocalDatabaseCheck {
  id        Int      @id @default(autoincrement())
  message   String   @default("local database is reachable")
  createdAt DateTime @default(now())
}

model User {
  id                     Int                             @id @default(autoincrement())
  email                  String                          @unique
  displayName            String
  role                   UserRole
  passwordHash           String?
  accountStatus          AccountStatus                   @default(ACTIVE)
  yearGroup              String?
  isDevelopmentUser      Boolean                         @default(true)
  createdAt              DateTime                        @default(now())
  updatedAt              DateTime                        @updatedAt
  teachingClasses        Class[]                         @relation("ClassTeacher")
  classEnrollments       ClassEnrollment[]
  createdAssignments     HomeworkAssignment[]            @relation("HomeworkAssignmentCreator")
  homeworkSubmissions    Submission[]                    @relation("SubmissionStudent")
  feedbackEntries        ParticipantFeedback[]           @relation("ParticipantFeedbackStudent")
  curriculumLibraryItems CurriculumHomeworkLibraryItem[] @relation("CurriculumLibraryItemCreator")
  departmentMemberships DepartmentTeamMembership[]
  curriculumLibraryItemVersions CurriculumHomeworkLibraryItemVersion[] @relation("CurriculumLibraryVersionEditor")
}

model Class {
  id                  Int                  @id @default(autoincrement())
  name                String               @unique
  subject             String               @default("General")
  description         String
  teacherId           Int
  status              ClassStatus          @default(ACTIVE)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  teacher             User                 @relation("ClassTeacher", fields: [teacherId], references: [id])
  enrollments         ClassEnrollment[]
  homeworkAssignments HomeworkAssignment[]
}

model ClassEnrollment {
  id        Int      @id @default(autoincrement())
  classId   Int
  studentId Int
  createdAt DateTime @default(now())
  class     Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  student   User     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([classId, studentId])
}

model HomeworkAssignment {
  id                  Int                            @id @default(autoincrement())
  classId             Int
  createdById         Int
  title               String
  titleI18n           Json?
  description         String?
  descriptionI18n     Json?
  keyVocabulary       Json?
  status              HomeworkAssignmentStatus       @default(DRAFT)
  dueAt               DateTime?
  sourceLibraryItemId Int?
  sourceLibraryVersion Int?
  createdAt           DateTime                       @default(now())
  updatedAt           DateTime                       @updatedAt
  class               Class                          @relation(fields: [classId], references: [id], onDelete: Cascade)
  createdBy           User                           @relation("HomeworkAssignmentCreator", fields: [createdById], references: [id])
  questions           HomeworkQuestion[]
  submissions         Submission[]
  feedbackImports     FeedbackImport[]
  participantFeedback ParticipantFeedback[]
  sourceLibraryItem   CurriculumHomeworkLibraryItem? @relation("HomeworkAssignmentSourceLibraryItem", fields: [sourceLibraryItemId], references: [id], onDelete: SetNull)

  @@index([classId])
  @@index([createdById])
  @@index([sourceLibraryItemId])
  @@index([sourceLibraryItemId, sourceLibraryVersion])
}

model HomeworkQuestion {
  id              Int                  @id @default(autoincrement())
  assignmentId    Int
  order           Int
  prompt          String
  promptI18n      Json?
  questionType    HomeworkQuestionType @default(OPEN_TEXT)
  responseMode    HomeworkQuestionResponseMode @default(TEXT)
  options         Json?
  imagePath       String?
  imageCaption    String?
  imageAltText    String?
  points          Int?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  assignment      HomeworkAssignment   @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  answers         SubmissionAnswer[]
  feedbackEntries QuestionFeedback[]

  @@unique([assignmentId, order])
  @@index([assignmentId])
}

model Submission {
  id              Int                   @id @default(autoincrement())
  assignmentId    Int
  studentId       Int
  status          SubmissionStatus      @default(DRAFT)
  submittedAt     DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  assignment      HomeworkAssignment    @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student         User                  @relation("SubmissionStudent", fields: [studentId], references: [id], onDelete: Cascade)
  answers         SubmissionAnswer[]
  feedbackEntries ParticipantFeedback[]

  @@unique([assignmentId, studentId])
  @@index([assignmentId])
  @@index([studentId])
}

model SubmissionAnswer {
  id           Int               @id @default(autoincrement())
  submissionId Int
  questionId   Int?
  answerText   String
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  submission   Submission        @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  question     HomeworkQuestion? @relation(fields: [questionId], references: [id], onDelete: SetNull)

  @@unique([submissionId, questionId])
  @@index([submissionId])
  @@index([questionId])
}

model FeedbackImport {
  id                      Int                   @id @default(autoincrement())
  assignmentId            Int
  feedbackFormat          String                @default("homework-feedback")
  feedbackVersion         Int                   @default(1)
  sourceExportFormat      String?
  sourceExportVersion     Int?
  sourceExportGeneratedAt DateTime?
  generatedBy             String?
  generatedAt             DateTime?
  importPayloadHash       String?
  importedById            Int?
  classId                 Int?
  operationSummary        Json?
  importedAt              DateTime              @default(now())
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  assignment              HomeworkAssignment    @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  participantFeedback     ParticipantFeedback[]

  @@unique([assignmentId, importPayloadHash])
  @@index([assignmentId])
}

model ParticipantFeedback {
  id                     Int                      @id @default(autoincrement())
  feedbackImportId       Int
  assignmentId           Int
  studentId              Int?
  submissionId           Int?
  sourceParticipantId    Int?
  sourceParticipantName  String?
  sourceParticipantEmail String?
  sourceSubmissionId     Int?
  sourceSubmissionStatus String?
  releaseState           FeedbackReleaseState     @default(RELEASED)
  importedAt             DateTime                 @default(now())
  importedById           Int?
  importAction           String                   @default("created")
  releasedAt             DateTime?
  releasedById           Int?
  overallFeedback        String
  overallFeedbackI18n    Json?
  strengths              String[]
  strengthsI18n          Json?
  targets                String[]
  targetsI18n            Json?
  teacherNotes           String?
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  feedbackImport         FeedbackImport           @relation(fields: [feedbackImportId], references: [id], onDelete: Cascade)
  assignment             HomeworkAssignment       @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student                User?                    @relation("ParticipantFeedbackStudent", fields: [studentId], references: [id], onDelete: SetNull)
  submission             Submission?              @relation(fields: [submissionId], references: [id], onDelete: SetNull)
  questionFeedback       QuestionFeedback[]
  followUpActions        FeedbackFollowUpAction[]

  @@unique([assignmentId, studentId, submissionId])
  @@index([feedbackImportId])
  @@index([assignmentId])
  @@index([studentId])
  @@index([submissionId])
  @@index([releaseState])
}

model QuestionFeedback {
  id                    Int                      @id @default(autoincrement())
  participantFeedbackId Int
  questionId            Int?
  sourceQuestionId      Int?
  questionOrder         Int?
  feedback              String
  feedbackI18n          Json?
  strengths             String[]                 @default([])
  strengthsI18n         Json?
  targets               String[]                 @default([])
  targetsI18n           Json?
  teacherNotes          String?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  participantFeedback   ParticipantFeedback      @relation(fields: [participantFeedbackId], references: [id], onDelete: Cascade)
  question              HomeworkQuestion?        @relation(fields: [questionId], references: [id], onDelete: SetNull)
  followUpActions       FeedbackFollowUpAction[]

  @@index([participantFeedbackId])
  @@index([questionId])
}

model FeedbackFollowUpAction {
  id                    Int                          @id @default(autoincrement())
  participantFeedbackId Int
  questionFeedbackId    Int?
  sourceActionId        String
  type                  FeedbackFollowUpActionType
  prompt                String
  promptI18n            Json?
  required              Boolean                      @default(true)
  status                FeedbackFollowUpActionStatus @default(PENDING)
  responseText          String?
  completedAt           DateTime?
  createdAt             DateTime                     @default(now())
  updatedAt             DateTime                     @updatedAt
  participantFeedback   ParticipantFeedback          @relation(fields: [participantFeedbackId], references: [id], onDelete: Cascade)
  questionFeedback      QuestionFeedback?            @relation(fields: [questionFeedbackId], references: [id], onDelete: Cascade)

  @@unique([participantFeedbackId, sourceActionId])
  @@index([participantFeedbackId])
  @@index([questionFeedbackId])
  @@index([status])
}

model TimetableImport {
  id              Int            @id @default(autoincrement())
  name            String
  sourceFilename  String
  isActive        Boolean        @default(false)
  rawAnalysisJson Json
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  dutySchedules   DutySchedule[]

  @@index([isActive])
  @@index([updatedAt])
}

model DutySchedule {
  id                      Int              @id @default(autoincrement())
  name                    String
  isActive                Boolean          @default(false)
  sourceTimetableImportId Int?
  sourceTimetableName     String?
  scheduleJson            Json
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt
  sourceTimetableImport   TimetableImport? @relation(fields: [sourceTimetableImportId], references: [id], onDelete: SetNull)

  @@index([isActive])
  @@index([sourceTimetableImportId])
  @@index([updatedAt])
}

model DepartmentTeam {
  id          Int                        @id @default(autoincrement())
  name        String                     @unique
  description String?
  createdAt   DateTime                   @default(now())
  updatedAt   DateTime                   @updatedAt
  memberships DepartmentTeamMembership[]
  libraryItems CurriculumHomeworkLibraryItem[]
}

model DepartmentTeamMembership {
  id        Int                @id @default(autoincrement())
  teamId    Int
  userId    Int
  role      DepartmentTeamRole @default(MEMBER)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  team      DepartmentTeam     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId])
}

model CurriculumHomeworkLibraryItem {
  id                 Int                  @id @default(autoincrement())
  title              String
  subject            String?
  yearGroup          String?
  unitTopic          String?
  tags               String[]
  assignmentJson     Json
  sourceAssignmentId Int?
  createdById        Int?
  visibility         CurriculumLibraryVisibility @default(PRIVATE)
  teamId             Int?
  createdAt          DateTime             @default(now())
  version            Int                  @default(1)
  archivedAt         DateTime?
  updatedById        Int?
  updatedAt          DateTime             @updatedAt
  createdBy          User?                @relation("CurriculumLibraryItemCreator", fields: [createdById], references: [id], onDelete: SetNull)
  team               DepartmentTeam?      @relation(fields: [teamId], references: [id], onDelete: SetNull)
  assignedCopies     HomeworkAssignment[] @relation("HomeworkAssignmentSourceLibraryItem")
  versions           CurriculumHomeworkLibraryItemVersion[]

  @@index([createdById])
  @@index([teamId])
  @@index([visibility])
  @@index([sourceAssignmentId])
  @@index([archivedAt])
}

model CurriculumHomeworkLibraryItemVersion {
  id            Int       @id @default(autoincrement())
  libraryItemId Int
  version       Int
  snapshotJson  Json
  editedById    Int?
  editedAt      DateTime  @default(now())
  libraryItem   CurriculumHomeworkLibraryItem @relation(fields: [libraryItemId], references: [id], onDelete: Cascade)
  editedBy      User?     @relation("CurriculumLibraryVersionEditor", fields: [editedById], references: [id], onDelete: SetNull)

  @@unique([libraryItemId, version])
  @@index([editedById])
  @@index([editedAt])
}
